{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "instructions/INSTRUCTIONS.md",
    "rules/KARPATHY.md",
    "rules/ORCHESTRATION.md",
    "rules/advanced-architecture.md"
  ],
  "plugin": [
    "/home/f0x017/Desktop/OmniRule/.omnirule-local/plugins/index.ts"
  ],
  "agent": {
    "architect": {
      "description": "Principal System Architect. System design, scalability, and technical strategy. Orchestrates the entire fleet.",
      "mode": "primary",
      "prompt": "{file:agents/ARCHITECT_AGENT.md}",
      "tools": {
        "read": true, "grep": true, "glob": true,
        "write": "ask", "bash": "ask", "delete": "ask",
        "burst": true, "adr": true, "schema": true
      },
      "capabilities": {
        "subAgents": ["qa-specialist", "security-officer", "infra-specialist", "devops-engineer", "context-specialist"],
        "maxParallel": 3
      }
    },
    "qa-specialist": {
      "description": "TDD and Quality Gate expert. Enforces 80%+ test coverage.",
      "mode": "subagent",
      "prompt": "{file:agents/QA_AGENT.md}",
      "tools": {
        "read": true, "write": "ask", "bash": "ask",
        "quality": true, "coverage": true
      }
    },
    "security-officer": {
      "description": "Threat modeling and Red-Team specialist. Zero-trust enforcer.",
      "mode": "subagent",
      "prompt": "{file:agents/SECURITY_AGENT.md}",
      "tools": {
        "read": true, "write": "ask", "bash": "ask",
        "red-team": true, "sentinel": true
      }
    },
    "style-architect": {
      "description": "Visual reverse-engineering and Design Tokens specialist.",
      "mode": "subagent",
      "prompt": "{file:agents/STYLE_AGENT.md}",
      "tools": {
        "read": true, "write": "ask", "visual": true
      }
    },
    "devops-engineer": {
      "description": "CI/CD, Docker, and Infrastructure automation expert.",
      "mode": "subagent",
      "prompt": "{file:agents/DEVOPS_AGENT.md}",
      "tools": {
        "read": true, "bash": "ask", "write": "ask"
      }
    }
  },
  "command": {
    "plan": {
      "description": "Strategic implementation planning",
      "template": "{file:commands/plan.md}\n\n$ARGUMENTS",
      "agent": "architect",
      "subtask": true
    },
    "tdd": {
      "description": "Red-Green-Refactor TDD Workflow",
      "template": "{file:commands/tdd.md}\n\n$ARGUMENTS",
      "agent": "qa-specialist",
      "subtask": true
    }
  },
  "permission": {
    "write_to_file": "ask",
    "replace_file_content": "ask",
    "run_command": "ask",
    "delete_file": "ask",
    "mcp_*": "ask"
  }
}
