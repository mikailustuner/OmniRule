{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "instructions": [
    "AGENTS.md",
    "instructions/INSTRUCTIONS.md",
    "rules/KARPATHY.md",
    "rules/TOOL_CATALOG.md",
    "rules/ORCHESTRATION.md",
    ".designrules/AGENT_INSTRUCTIONS.md"
  ],
  "plugin": [
    "{{CONFIG_DIR}}/plugins/index.ts"
  ],
  "agent": {
    "orchestrator": {
      "description": "Main entry point. Routes every task to the right specialist agent. Always start here.",
      "mode": "primary",
      "prompt": "{file:agents/ORCHESTRATOR_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/blueprint/SKILL.md}\n{file:skills/clean-architecture/SKILL.md}\n{file:skills/typescript-expert/SKILL.md}",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "write": true,
        "bash": true,
        "delete": false,
        "mcp": true
      },
      "capabilities": {
        "subAgents": [
          "architect",
          "style-architect",
          "frontend-ops",
          "qa-specialist",
          "security-officer",
          "devops-engineer",
          "infra-specialist",
          "seo-agent",
          "researcher",
          "docs-agent",
          "context-agent",
          "migrator",
          "mobile-ops",
          "document-creator",
          "ai-engineer",
          "cloud-architect",
          "blockchain-developer",
          "data-engineer",
          "security-expert",
          "platform-engineer",
          "swift-developer"
        ],
        "maxParallel": 4
      }
    },
    "architect": {
      "description": "Principal System Architect. System design, scalability, and technical strategy.",
      "mode": "subagent",
      "prompt": "{file:agents/ARCHITECT_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/clean-architecture/SKILL.md}\n{file:skills/hexagonal-architecture/SKILL.md}\n{file:skills/ddd-patterns/SKILL.md}\n{file:skills/microservices-patterns/SKILL.md}",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "write": true,
        "bash": true,
        "delete": false
      }
    },
    "style-architect": {
      "description": "Visual reverse-engineering and Design Tokens specialist. Runs frontend-extractor tool.",
      "mode": "subagent",
      "prompt": "{file:agents/STYLE_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/tailwind-expert/SKILL.md}\n{file:skills/css-architecture/SKILL.md}\n{file:skills/css-variables/SKILL.md}\n{file:skills/responsive-design/SKILL.md}\n{file:skills/animations-patterns/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true
      }
    },
    "frontend-ops": {
      "description": "React, state management, and bundle optimization specialist.",
      "mode": "subagent",
      "prompt": "{file:agents/FRONTEND_OPS_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/react-expert/SKILL.md}\n{file:skills/nextjs-expert/SKILL.md}\n{file:skills/state-management/SKILL.md}\n{file:skills/bundle-optimization/SKILL.md}\n{file:skills/web-performance/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true
      }
    },
    "qa-specialist": {
      "description": "TDD and Quality Gate expert. E2E testing with Playwright.",
      "mode": "subagent",
      "prompt": "{file:agents/QA_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/testing-patterns/SKILL.md}\n{file:skills/debugging-strategies/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true
      }
    },
    "security-officer": {
      "description": "Threat modeling and Red-Team specialist. Zero-trust enforcer.",
      "mode": "subagent",
      "prompt": "{file:agents/SECURITY_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/security-review/SKILL.md}\n{file:skills/authentication-patterns/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true
      }
    },
    "devops-engineer": {
      "description": "CI/CD, Docker, Kubernetes, and Infrastructure automation.",
      "mode": "subagent",
      "prompt": "{file:agents/DEVOPS_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/docker-patterns/SKILL.md}\n{file:skills/ci-cd-patterns/SKILL.md}\n{file:skills/kubernetes-basics/SKILL.md}\n{file:skills/terraform-basics/SKILL.md}",
      "tools": {
        "read": true,
        "bash": true,
        "write": true
      }
    },
    "infra-specialist": {
      "description": "Database, Redis, caching, and message queue expert.",
      "mode": "subagent",
      "prompt": "{file:agents/INFRA_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/postgres-patterns/SKILL.md}\n{file:skills/redis-patterns/SKILL.md}\n{file:skills/caching-patterns/SKILL.md}\n{file:skills/message-queues/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true
      }
    },
    "seo-agent": {
      "description": "Search visibility, Core Web Vitals, and semantic HTML specialist.",
      "mode": "subagent",
      "prompt": "{file:agents/SEO_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/html-semantic/SKILL.md}\n{file:skills/web-performance/SKILL.md}\n{file:skills/accessibility-basics/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true
      }
    },
    "researcher": {
      "description": "Deep research, business ops (HR, Legal, Marketing, Finance), data analysis, and technical intelligence.",
      "mode": "subagent",
      "prompt": "{file:agents/RESEARCHER.md}\n\n---\n## Loaded Skills\n{file:skills/documentation-patterns/SKILL.md}\n{file:skills/code-review-patterns/SKILL.md}\n{file:skills/bond-analyzer/SKILL.md}",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "bash": true,
        "write": true,
        "browser": true
      }
    },
    "docs-agent": {
      "description": "Technical documentation, OpenAPI specs, and README precision.",
      "mode": "subagent",
      "prompt": "{file:agents/DOCS_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/documentation-patterns/SKILL.md}\n{file:skills/api-design/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true
      }
    },
    "context-agent": {
      "description": "DB schema mapping and business logic inference. Prisma expert.",
      "mode": "subagent",
      "prompt": "{file:agents/CONTEXT_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/prisma-expert/SKILL.md}\n{file:skills/postgres-patterns/SKILL.md}\n{file:skills/ddd-patterns/SKILL.md}",
      "tools": {
        "read": true,
        "bash": true
      }
    },
    "migrator": {
      "description": "Database migration and schema evolution specialist.",
      "mode": "subagent",
      "prompt": "{file:agents/MIGRATOR_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/prisma-expert/SKILL.md}\n{file:skills/postgres-patterns/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true
      }
    },
    "mobile-ops": {
      "description": "Specialist for React Native and Expo development.",
      "mode": "subagent",
      "prompt": "{file:agents/MOBILE_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/mobile-patterns/SKILL.md}\n{file:skills/react-expert/SKILL.md}\n{file:skills/typescript-expert/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true
      }
    },
    "document-creator": {
      "description": "Professional PDF and PPTX document generation. IBM/McKinsey style. Research → structure → generate.",
      "mode": "subagent",
      "prompt": "{file:agents/DOCUMENT_CREATOR_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/professional-report-design/SKILL.md}\n{file:skills/professional-pptx-design/SKILL.md}\n{file:skills/documentation-patterns/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true,
        "grep": true,
        "glob": true
      }
    },
    "ai-engineer": {
      "description": "AI/ML integration specialist for LLM, Vector DB, Prompt Engineering, and MLOps.",
      "mode": "subagent",
      "prompt": "{file:agents/AI_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/llm-integration/SKILL.md}\n{file:skills/vector-db-patterns/SKILL.md}\n{file:skills/prompt-engineering/SKILL.md}\n{file:skills/mlops-patterns/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true
      }
    },
    "cloud-architect": {
      "description": "Cloud platform specialist for AWS, GCP, and Azure architecture patterns.",
      "mode": "subagent",
      "prompt": "{file:agents/CLOUD_ARCHITECT.md}\n\n---\n## Loaded Skills\n{file:skills/aws-patterns/SKILL.md}\n{file:skills/gcp-patterns/SKILL.md}\n{file:skills/azure-patterns/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true
      }
    },
    "blockchain-developer": {
      "description": "Blockchain and smart contract specialist for Solidity, DeFi, and Web3.",
      "mode": "subagent",
      "prompt": "{file:agents/BLOCKCHAIN_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/solidity-patterns/SKILL.md}\n{file:skills/smart-contract-testing/SKILL.md}\n{file:skills/defi-patterns/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true
      }
    },
    "data-engineer": {
      "description": "Data engineering specialist for ETL pipelines, data warehousing, and streaming systems.",
      "mode": "subagent",
      "prompt": "{file:agents/DATA_ENGINEER.md}\n\n---\n## Loaded Skills\n{file:skills/etl-patterns/SKILL.md}\n{file:skills/data-pipeline-patterns/SKILL.md}\n{file:skills/streaming-patterns/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true
      }
    },
    "security-expert": {
      "description": "Advanced security specialist for network security, cryptography, and compliance (GDPR, SOC2).",
      "mode": "subagent",
      "prompt": "{file:agents/SECURITY_EXPERT.md}\n\n---\n## Loaded Skills\n{file:skills/network-security/SKILL.md}\n{file:skills/cryptography-patterns/SKILL.md}\n{file:skills/compliance-gdpr/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true
      }
    },
    "platform-engineer": {
      "description": "Internal platform and developer experience specialist for self-service infrastructure.",
      "mode": "subagent",
      "prompt": "{file:agents/PLATFORM_ENGINEER.md}\n\n---\n## Loaded Skills\n{file:skills/internal-platforms/SKILL.md}\n{file:skills/developer-experience/SKILL.md}\n{file:skills/chaos-engineering/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true
      }
    },
    "swift-developer": {
      "description": "Apple platform specialist for Swift, SwiftUI, iOS, watchOS, macOS, and Apple design guidelines.",
      "mode": "subagent",
      "prompt": "{file:agents/SWIFT_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/swiftui-patterns/SKILL.md}\n{file:skills/watchos-patterns/SKILL.md}\n{file:skills/apple-design-guidelines/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true
      }
    },
    "computer-operator": {
      "description": "Masaüstü bilgisayar kontrolü, tarayıcı otomasyonu, dosya ve süreç yönetimi.",
      "mode": "subagent",
      "prompt": "{file:agents/COMPUTER_OPERATOR_AGENT.md}\n\n---\n## Loaded Skills\n{file:skills/computer-use/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true,
        "glob": true,
        "list_dir": true,
        "computer": true,
        "browser": true
      }
    }
  },
  "command": {
    "orchestrate": {
      "description": "Route any task through the full agent fleet",
      "template": "{file:commands/orchestrate.md}\n\n$ARGUMENTS",
      "agent": "orchestrator",
      "subtask": true
    },
    "extract": {
      "description": "Extract design tokens and screenshots from a live URL",
      "template": "Run: npm run tool:extract -- $ARGUMENTS\nThen read .design/ output and summarize the design system.",
      "agent": "style-architect",
      "subtask": true
    },
    "design": {
      "description": "Analyze or apply a design system from .design/ tokens",
      "template": "{file:commands/design.md}\n\n$ARGUMENTS",
      "agent": "style-architect",
      "subtask": true
    },
    "plan": {
      "description": "Strategic implementation planning",
      "template": "{file:commands/plan.md}\n\n$ARGUMENTS",
      "agent": "architect",
      "subtask": true
    },
    "tdd": {
      "description": "Red-Green-Refactor TDD Workflow",
      "template": "{file:commands/tdd.md}\n\n$ARGUMENTS",
      "agent": "qa-specialist",
      "subtask": true
    },
    "review": {
      "description": "Deep code review: security + quality + architecture",
      "template": "{file:commands/review.md}\n\n$ARGUMENTS",
      "agent": "security-officer",
      "subtask": true
    },
    "security": {
      "description": "Security audit and threat modeling",
      "template": "{file:commands/security.md}\n\n$ARGUMENTS",
      "agent": "security-officer",
      "subtask": true
    },
    "refactor": {
      "description": "Structured code refactoring",
      "template": "{file:commands/refactor.md}\n\n$ARGUMENTS",
      "agent": "architect",
      "subtask": true
    },
    "research": {
      "description": "Deep investigation and documentation lookup",
      "template": "{file:commands/research.md}\n\n$ARGUMENTS",
      "agent": "researcher",
      "subtask": true
    },
    "docs": {
      "description": "Generate or update documentation",
      "template": "{file:commands/documentation.md}\n\n$ARGUMENTS",
      "agent": "docs-agent",
      "subtask": true
    },
    "build-fix": {
      "description": "Diagnose and fix build failures",
      "template": "{file:commands/build-fix.md}\n\n$ARGUMENTS",
      "agent": "devops-engineer",
      "subtask": true
    },
    "api": {
      "description": "API generation, OpenAPI scaffolding, route documentation",
      "template": "{file:commands/api.md}\n\n$ARGUMENTS",
      "agent": "architect",
      "subtask": true
    },
    "perf": {
      "description": "Performance audit — Core Web Vitals via real browser",
      "template": "{file:commands/perf.md}\n\n$ARGUMENTS",
      "agent": "frontend-ops",
      "subtask": true
    },
    "mobile": {
      "description": "React Native / Expo mobile development",
      "template": "{file:commands/mobile.md}\n\n$ARGUMENTS",
      "agent": "mobile-ops",
      "subtask": true
    },
    "mode": {
      "description": "Switch agent behavior mode (dev / research / review)",
      "template": "{file:commands/mode.md}\n\n$ARGUMENTS",
      "agent": "orchestrator",
      "subtask": true
    },
    "agent": {
      "description": "Directly dispatch a specific specialist agent by name",
      "template": "{file:commands/agent.md}\n\n$ARGUMENTS",
      "agent": "orchestrator",
      "subtask": true
    },
    "migrate": {
      "description": "Manage database schema migrations and evolution.",
      "template": "{file:commands/migrate.md}\n\n$ARGUMENTS",
      "agent": "migrator",
      "subtask": true
    },
    "skills": {
      "description": "Detect required skills for the current project. AUTO-INVOKE at session start.",
      "template": "npm run tool:skills 2>&1"
    },
    "deps": {
      "description": "Scan package.json for vulnerable or deprecated packages. AUTO-INVOKE at session start.",
      "template": "npm run tool:deps 2>&1"
    },
    "compact": {
      "description": "Build a critical context snapshot to survive context window compaction. AUTO-INVOKE when context is getting large.",
      "template": "npm run tool:compact 2>&1"
    },
    "verify": {
      "description": "Run TypeScript + ESLint checks. AUTO-INVOKE after implementation tasks before reporting done.",
      "template": "npm run omnirule:verify 2>&1"
    },
    "security-scan": {
      "description": "Scan changed files for security vulnerabilities. AUTO-INVOKE before any commit or when auth/API files are edited.",
      "template": "npm run tool:security 2>&1"
    },
    "check": {
      "description": "Run all checks: deps + security + quality. Use before PR or major task completion.",
      "template": "npm run omnirule:check 2>&1"
    },
  },
  "permission": {
    "write_to_file": "ask",
    "replace_file_content": "ask",
    "run_command": "ask",
    "delete_file": "ask",
    "mcp_*": "ask"
  }
}