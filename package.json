{
  "scripts": {
    "omnirule:init": "node scripts/hooks/session-start.js",
    "omnirule:verify": "node scripts/hooks/quality-gate.js",
    "tool:skills": "tsx tools/skill-detector.ts",
    "tool:extract": "tsx tools/frontend-extractor.ts",
    "tool:extract:install": "npx playwright install chromium",
    "tool:security": "tsx tools/security-audit.ts",
    "tool:deps": "tsx tools/dependency-sentinel.ts",
    "tool:compact": "tsx tools/context-compactor.ts",
    "agents:list": "node -e \"const fs=require('fs');fs.readdirSync('agents').forEach(f=>console.log(f.replace('_AGENT.md','').toLowerCase()))\"",
    "tools:list": "node -e \"const fs=require('fs');const p=JSON.parse(fs.readFileSync('package.json','utf8'));Object.keys(p.scripts).filter(k=>k.startsWith('tool:')).forEach(k=>console.log(k))\"",
    "omnirule:check": "tsx tools/dependency-sentinel.ts && tsx tools/security-audit.ts && node scripts/hooks/quality-gate.js",
    "registry": "node -e \"const r=JSON.parse(require('fs').readFileSync('registry.json','utf8'));console.log('Agents:',r.agents.length,'Tools:',r.tools.length,'Commands:',r.commands.length,'Skills:',r.skills.count)\"",
    "omnirule:full": "npm run tool:deps && npm run tool:security && npm run omnirule:verify",
    "hooks:install": "npx lefthook install",
    "hooks:uninstall": "npx lefthook uninstall",
    "hooks:run": "npx lefthook run pre-commit"
  },
  "version": "1.15.0",
  "type": "module",
  "dependencies": {
    "@prisma/client": "latest",
    "fs-extra": "^11.2.0",
    "next": "latest",
    "picocolors": "^1.0.0",
    "playwright": "^1.59.1",
    "react": "latest",
    "tailwindcss": "latest",
    "ts-node": "latest",
    "typescript": "latest",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@clack/prompts": "^1.3.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "commander": "^14.0.3",
    "lefthook": "^1.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0"
  }
}